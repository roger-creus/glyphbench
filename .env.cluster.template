# .env.cluster.template — copy to .env.cluster (gitignored) and fill in.
#
# Required by scripts/rl/launch_*.sh. Anyone training glyphbench RL on
# their own cluster fills this in once.

# --- Node hostnames (must be SSH-reachable from the trainer node) ---
# Trainer + orchestrator run on TRAINER_NODE.
# Inference vLLM workers run on each entry of INFERENCE_NODES (bash array).
TRAINER_NODE=sf-node-1
INFERENCE_NODES=(sf-node-2 sf-node-3)

# --- Networking ---
# Port the inference vLLM HTTP server listens on (same on every inference node).
INFERENCE_PORT=8000
# A long random string. Used as `--api-key` on the vLLM server side and
# `OPENAI_API_KEY_INFERENCE` on the orchestrator side.
INFERENCE_SERVER_API_KEY=<generate-with-openssl-rand-hex-32>
# Reachable IP of the trainer node from the inference nodes' POV. Used for
# NCCL weight broadcast (the trainer is the broadcast master).
TRAINER_NODE_IP=<the-91.x-IP-of-sf-node-1>
NCCL_PORT=29501
# Network interface NCCL binds to. ens1 on these nodes. If your cluster
# has a private fast interface, use that one instead.
NCCL_SOCKET_IFNAME=ens1

# --- Paths ---
# Persistent output dir for THIS run on the trainer node (local FS — no
# shared FS required because trainer + orchestrator co-locate).
OUTPUT_DIR=/home/roger/glyphbench/outputs/qwen35-4b-glyphbench-v1

# --- Logging ---
WANDB_API_KEY=<your-wandb-key>
# Optional: HF token for model download (gated/private models). Qwen3.5-4B
# is public so this is only needed if you proxy via a private mirror.
HF_TOKEN=
